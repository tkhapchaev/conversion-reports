{
	"ConnectionStrings": {
		"Postgres": "Host=localhost;Port=5432;Database=conversion_reports;Username=postgres;Password=postgres"
	},
	"Kafka": {
		"BootstrapServers": "localhost:9094",
		"TopicName": "report-requests",
		"ConsumerGroupId": "conversion-reports-service",
		"AutoOffsetReset": "Earliest"
	},
	"Batching": {
		"MaxWaitTime": "1.00:00:00",
		"ProcessingInterval": "00:00:15"
	},
	"Caching": {
		"PendingTtl": "00:00:05",
		"CompletedTtl": "00:10:00",
		"FailedTtl": "00:01:00"
	},
	"Logging": {
		"LogLevel": {
			"Default": "Information",
			"Microsoft.AspNetCore": "Warning"
		}
	},
	"AllowedHosts": "*"
}
